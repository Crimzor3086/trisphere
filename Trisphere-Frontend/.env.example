# TriSphere unified frontend (port 3000)
# Backends run separately on fixed ports — see root README.md

# Client-side API bases (proxied via next.config.mjs rewrites)
NEXT_PUBLIC_BOARDY_API_URL=/api/boardy
NEXT_PUBLIC_KHC_API_URL=/api/khc
NEXT_PUBLIC_TREND_API_URL=/api/trend

# Server-side direct backend URLs (SSR / server actions)
BOARDY_API_URL=http://localhost:4000
KHC_API_URL=http://localhost:5000/api
TREND_API_URL=http://localhost:8000

# Avalanche Fuji (chainId 43113)
NEXT_PUBLIC_AVALANCHE_CHAIN_ID=43113
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployed contract addresses (set after npm run deploy:fuji from repo root)
NEXT_PUBLIC_TREND_REGISTRY_ADDRESS=
NEXT_PUBLIC_KHC_REGISTRY_ADDRESS=
NEXT_PUBLIC_BOARDY_MATCH_STAKING_ADDRESS=
NEXT_PUBLIC_BOARDY_MILESTONE_ESCROW_ADDRESS=
NEXT_PUBLIC_BOARDY_STAKE_AMOUNT_AVAX=0.01

# Commerce layer (PaymentEscrow, Treasury, Reputation, MockUSDC)
NEXT_PUBLIC_PAYMENT_ESCROW_ADDRESS=
NEXT_PUBLIC_TRISPHERE_TREASURY_ADDRESS=
NEXT_PUBLIC_TRISPHERE_REPUTATION_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=
NEXT_PUBLIC_PLATFORM_FEE_BPS=250

# Server-only: owner key for createMatch / milestone / counter-stake (same deployer wallet)
BOARDY_OWNER_PRIVATE_KEY=
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
BOARDY_COUNTERPARTY_ADDRESS=

# Boardy matchmaking (Thirdweb + Vapi)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
