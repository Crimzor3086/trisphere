RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
PRIVATE_KEY=<YOUR-WALLET-PRIVATE-KEY>

# KHCRegistry — populated after: npm run deploy:fuji
KHC_REGISTRY_ADDRESS=<deployed-KHCRegistry-address>

# Set to "true" to auto-register Qualified champions on-chain after pipeline runs
CHAIN_AUTO_SYNC=false

# Optional: Snowtrace API key for contract verification
SNOWTRACE_API_KEY=<your-snowtrace-api-key>

# Backend port (default 5000)
PORT=5000
