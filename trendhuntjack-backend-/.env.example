# Copy this file to .env and fill in your values.
# Never commit your .env file. It is in .gitignore.
# Never share your private key with anyone.

# Your wallet private key — export from Core Wallet or MetaMask
# This is used for deploying contracts to Fuji testnet
# Use a wallet that holds only testnet AVAX, never mainnet funds
PRIVATE_KEY=your_wallet_private_key_here

# Snowtrace API key for contract verification on Fuji
# Get one free at: https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=your_snowtrace_api_key_here

# Alchemy or Infura RPC URL (optional — the default Fuji RPC works without this)
# Alchemy free tier: https://alchemy.com
# Infura free tier: https://infura.io
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# --- Week 3 onwards: M-Pesa Daraja API ---

# Get these from your approved app on https://developer.safaricom.co.ke
DARAJA_CONSUMER_KEY=your_daraja_consumer_key_here
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret_here

# Your Daraja sandbox shortcode (provided in the sandbox)
DARAJA_SHORTCODE=174379

# Lipa Na M-Pesa Online passkey (provided in the sandbox)
DARAJA_PASSKEY=your_lipa_na_mpesa_passkey_here

# Your public webhook URL for STK Push callbacks
# During local development, use Ngrok: https://ngrok.com
# Example: https://abc123.ngrok.io/api/mpesa/callback
DARAJA_CALLBACK_URL=https://your-ngrok-url/api/mpesa/callback

# --- Trend Hunter backend ---

# FastAPI service
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
# Allow LAN IPs like http://192.168.x.x:8080 during local development
CORS_ALLOW_LOCAL_NETWORK=true

# Registry persistence (SQLite)
REGISTRY_DB_PATH=./data/registry.db

# Transaction confirmation timeout in seconds
TX_CONFIRMATION_TIMEOUT=120

# OpenAI / Claude keys for production AI classification and script generation
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Data stores
DATABASE_URL=postgresql://trendhunter:trendhunter@localhost:5432/trendhunter
# Optional Redis cache (omit or leave empty to use in-memory cache locally)
# REDIS_URL=redis://localhost:6379/0

# Avalanche registry service
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
TREND_REGISTRY_ADDRESS=your_deployed_trend_registry_address_here
REGISTRY_PRIVATE_KEY=your_backend_fuji_signer_private_key_here
